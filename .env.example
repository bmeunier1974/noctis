# Copy to `.env` (gitignored) and fill in — `noctis setup` does this for you.
# To run the full system you need a DataBento key (the research data lake) and ONE LLM
# key below — or none, when a local backend (e.g. noctis-ollama) serves the model.

# DataBento historical market-data API key (research/backtest ingests; free signup credit).
DATABENTO_API_KEY=

# LLM key for the hosted provider your config.yaml research.model names — set the one that
# matches its prefix (openai/… or anthropic/…). A local backend (ollama_chat/…) needs none.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# The live TRADING feed uses yfinance (Yahoo Finance) — free and credential-less; there is
# no secret to set for it.

# LIVE EXECUTION SAFETY GATE. Must be exactly `true` (with config mode: live) to
# arm real-money order paths. Leave unset/false for paper trading. This is one of
# two independent gates; config `mode: paper` always wins toward safety.
ALLOW_LIVE=
